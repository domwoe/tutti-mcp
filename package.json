{
  "name": "tutti-mcp",
  "version": "0.1.0",
  "description": "MCP server and CLI for searching tutti.ch classifieds.",
  "license": "MIT",
  "author": "domwoe",
  "homepage": "https://github.com/domwoe/tutti-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/domwoe/tutti-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/domwoe/tutti-mcp/issues"
  },
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "tutti-mcp": "./dist/mcp.js",
    "tutti": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "tutti-api": "^2.1.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  }
}
